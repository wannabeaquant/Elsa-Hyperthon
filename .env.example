# ── Wallet ──────────────────────────────────────────────────────────────────
# Fresh non-custodial wallet. Fund with 0.003 ETH + $25 USDC on Base mainnet.
PRIVATE_KEY=0x...

# ── Network ──────────────────────────────────────────────────────────────────
USE_MAINNET=true
BASE_RPC_URL=https://mainnet.base.org
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── Elsa API ─────────────────────────────────────────────────────────────────
X402_SERVER_URL=https://x402-api.heyelsa.ai

# ── Claude Code OAuth (from Claude Max/Pro subscription — no per-token billing)
CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token-here

# ── Agent Config ─────────────────────────────────────────────────────────────
# Wallet address (public key) for portfolio/balance queries
WALLET_ADDRESS=0x...

# Set to "true" during development. Flip to "false" for the live demo.
DRY_RUN=true

# How often the agent wakes up (milliseconds). 60000 = 1 minute.
INTERVAL_MS=60000
